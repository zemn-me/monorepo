load("//bzl:rules.bzl", "bazel_lint")
load("//ts:rules.bzl", "ts_project")

package(default_visibility = ["//visibility:public"])

exports_files(["sample.ts"])

bazel_lint(
    name = "bazel_lint",
    srcs = ["BUILD.bazel"],
    visibility = ["//:__subpackages__"],
)

ts_project(
    name = "uses_option",
    srcs = ["sample.ts"],
    visibility = ["//:__subpackages__"],
    deps = [
        "//:node_modules/@jest/globals",
        "//:node_modules/@types/node",
        "//go/gazelle/ts/testdata/dependency",  # keep
    ],
)

filegroup(
    name = "all_ts_srcs",
    srcs = ["sample.ts"],
    visibility = ["//:__subpackages__"],
)
