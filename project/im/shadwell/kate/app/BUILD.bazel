load("//bzl:rules.bzl", "bazel_lint")
load("//css/module:rules.bzl", "css_module")
load("//ts:rules.bzl", "ts_project")

ts_project(
    name = "app",
    srcs = [
        "layout.tsx",
        "page.tsx",
    ],
    assets = [
        "base.css",
        "page.module.css",
    ],
    visibility = ["//project/im/shadwell/kate:__pkg__"],
    deps = [
        ":page_module_css",
        "//:node_modules/@types/node",
        "//:node_modules/@types/react",
        "//:node_modules/@types/react-dom",
        "//:node_modules/next",
        "//:node_modules/react",
        "//:node_modules/react-dom",
        "//ts/next.js",
        "//ts/next.js/types/next-compiled",
    ],
)

bazel_lint(
    name = "bazel_lint",
    srcs = ["BUILD.bazel"],
    visibility = ["//:__subpackages__"],
)

filegroup(
    name = "all_ts_srcs",
    srcs = [
        "layout.tsx",
        "page.tsx",
    ],
    visibility = ["//:__subpackages__"],
)

css_module(
    name = "page_module_css",
    src = "page.module.css",
    visibility = ["//:__subpackages__"],
)
