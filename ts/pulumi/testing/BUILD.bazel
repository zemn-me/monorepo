service_test(
    name = "analytics_integration_test",
    flaky = True,
    services = [
        ":anna_itest_service",
        ":availability_itest_service",
        ":baby_itest_service",
        ":eggs_itest_service",
        ":kate_itest_service",
        ":luke_itest_service",
        ":lulu_itest_service",
        ":lucy_itest_service",
        ":pleaseintroducemetoyourdog_itest_service",
        "//java/software/amazon/dynamodb:dynamodb",
        "//project/zemn.me/api/cmd/localserver:localserver_itest_service",
    ],
    test = ":analytics_itest_test",
)

py_binary(
    name = "baby_itest_bin",
    srcs = ["//ts/pulumi/testing/inject_api_iservice:all_srcs"],
    data = [
        "//ts/pulumi/baby.computer:dev",
    ],
    env = {
        "NEXTJS_BINARY": "$(rlocationpath @@//ts/pulumi/baby.computer:dev)",
    },
    main = "inject_api_iservice.py",
    visibility = ["//:__subpackages__"],
    deps = ["//ts/pulumi/testing/inject_api_iservice"],
)

itest_service(
    name = "baby_itest_service",
    args = [
        "ts/pulumi/baby.computer",
        "--port",
        "$${PORT}",
    ],
    autoassign_port = True,
    exe = ":baby_itest_bin",
    deps = ["//project/zemn.me/api/cmd/localserver:localserver_itest_service"],
)

