load("@io_bazel_rules_go//go:def.bzl", "go_test")
load("//bzl:rules.bzl", "bazel_lint")

alias(
    name = "example",
    actual = "//ts/next.js/testing/example/app:remix",
)

alias(
    name = "build",
    actual = "//ts/next.js/testing/example/app:build",
)

alias(
    name = "dev",
    actual = "//ts/next.js/testing/example/app:dev",
)

alias(
    name = "start",
    actual = "//ts/next.js/testing/example/app:start",
)

bazel_lint(
    name = "bazel_lint",
    srcs = ["BUILD.bazel"],
)

go_test(
    name = "example_test",
    size = "small",
    srcs = ["launch_server_test.go"],
    data = [
        ":dev",
        ":start",
    ],
    env = {
        "NEXT_SERVER_BINARY": "$(rlocationpath :dev)",
        "NEXT_PROD_SERVER_BINARY": "$(rlocationpath :start)",
        "BAZEL_BINDIR": "$(BINDIR)",
    },
    deps = ["@io_bazel_rules_go//go/runfiles"],
)
